{
  "name": "vortex-notes",
  "version": "0.1.2",
  "description": "Markdown notes with a first-party MCP server and zero-config local semantic search. The vault your agents can actually use.",
  "type": "module",
  "license": "MIT",
  "bin": {
    "vortex-notes": "dist/cli.js"
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc && npm run build:web",
    "dev": "tsx src/cli.ts",
    "test": "node --test \"dist-test/test/*.test.js\"",
    "pretest": "tsc -p tsconfig.test.json",
    "build:web": "esbuild src/webapp/main.ts --bundle --minify --format=iife --platform=browser --outfile=dist/webapp/bundle.js",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "mcp",
    "notes",
    "markdown",
    "agent-memory",
    "knowledge-base",
    "semantic-search"
  ],
  "dependencies": {
    "@codemirror/lang-markdown": "^6.5.0",
    "@huggingface/transformers": "^3.3.0",
    "@lezer/highlight": "^1.2.3",
    "@modelcontextprotocol/sdk": "^1.12.0",
    "@noble/ciphers": "^2.2.0",
    "@noble/curves": "^2.2.0",
    "@noble/hashes": "^2.2.0",
    "@scure/bip39": "^2.2.0",
    "better-sqlite3": "^11.8.0",
    "chokidar": "^4.0.3",
    "codemirror": "^6.0.2",
    "gray-matter": "^4.0.3",
    "marked": "^15.0.12",
    "node-diff3": "^3.2.1",
    "sqlite-vec": "^0.1.6",
    "ulid": "^2.3.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^22.10.0",
    "esbuild": "^0.28.1",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/vortex-303/vortex-notes.git"
  },
  "homepage": "https://github.com/vortex-303/vortex-notes#readme"
}
